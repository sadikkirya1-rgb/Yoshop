rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to identify the single Master Admin account
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'Y0N3Ny1AX9VZEQb6AdRwhK8xpkg2' ||
        (request.auth.token.email != null && request.auth.token.email == 'sadikkirya@gmail.com')
      );
    }

    function isOwnerOrAdmin(userId) {
      return request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
    }

    // Root users collection
    match /users/{userId} {
      // Allow the authenticated user to create their own user document
      allow create: if request.auth != null && request.auth.uid == userId;

      // Allow the owning user OR an Admin to read, update, or delete the document
      allow get, update, delete: if isOwnerOrAdmin(userId);

      // Allow listing/querying the top-level /users collection only to the Master Admin
      allow list: if isAdmin();

      // Nested private shop assets, including shop_profile and sync_queue
      match /data/{document=**} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      // Transactions subcollection
      match /transactions/{transactionId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      // Production per-record collections
      match /customers/{recordId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }
      match /categories/{recordId} {
      allow read, write: if isOwnerOrAdmin(userId);
      }

      match /products/{recordId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /staff/{recordId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /units/{recordId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /inventory_history/{recordId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /audit_log/{recordId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }

      match /notifications/{recordId} {
        allow read, write: if isOwnerOrAdmin(userId);
      }
    }

    // Protect everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}