rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper to identify Master Admin by UID or email claim
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'Y0N3Ny1AX9VZEQb6AdRwhK8xpkg2' ||
        (request.auth.token.email != null && request.auth.token.email == 'sadikkirya@gmail.com')
      );
    }

    // Strict per-tenant isolation: files stored under /users/{userId}/** are only
    // accessible by that authenticated user or the Master Admin.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
